#Admin (THE-198) — base URL the magic-link callback returns to.
# Local dev: http://localhost:3000
# Production: https://admin.theanalog.company
# Vercel previews can leave this unset — the form falls back to NEXT_PUBLIC_VERCEL_URL.
NEXT_PUBLIC_ADMIN_URL=

# Langfuse Cloud project keys (THE-200). All three required for the agent
# to emit traces; leave blank locally to no-op. LANGFUSE_BASE_URL must be
# one of: https://us.cloud.langfuse.com (US) or https://cloud.langfuse.com (EU).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
