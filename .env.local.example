# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Voyage AI
VOYAGE_API_KEY=

#Sendblue
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=
SENDBLUE_SIGNING_SECRET=

#Slack
SLACK_ALERTS_WEBHOOK_URL=

#PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

#Google Drive
GOOGLE_DRIVE_VENUES_FOLDER_ID=

#Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_ID=

#Cron
CRON_SECRET=

#Admin (THE-198) — base URL the magic-link callback returns to.
# Local dev: http://localhost:3000
# Production: https://admin.theanalog.company
# Vercel previews can leave this unset — the form falls back to NEXT_PUBLIC_VERCEL_URL.
NEXT_PUBLIC_ADMIN_URL=

# Langfuse Cloud project keys (THE-200). Leave blank locally to no-op;
# set in Vercel env per environment to light up tracing in prod/preview.
# LANGFUSE_BASE_URL is the canonical name for the host; LANGFUSE_HOST is
# also accepted as a legacy alias (slated for removal post-pilot).
# Host must be one of:
#   https://us.cloud.langfuse.com  (US)
#   https://cloud.langfuse.com     (EU)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
